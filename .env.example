GARMIN_USERNAME=
GARMIN_PASSWORD=
# Optional 2FA options (choose one):
# - TOTP secret (base32 from your authenticator app)
# GARMIN_TOTP_SECRET=
# - Or a one-time MFA code (SMS/email). Set it just before running.
# GARMIN_MFA_CODE=

# Token persistence directory (recommended)
# Set to a directory to store OAuth tokens; ignored by git if under secrets/
# GARMINTOKENS=secrets/garmin_tokens
